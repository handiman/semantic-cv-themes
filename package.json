{
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:themeRegistry && tsc --project tsconfig.json",
    "build:themeRegistry": "node scripts/generate-themeRegistry.js ./",
    "test": "npm run build && node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results.xml *.test.js"
  },
  "devDependencies": {
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "jsdom": "^29.0.0"
  }
}
